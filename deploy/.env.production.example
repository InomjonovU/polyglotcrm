# ============================================================
# PolyglotLC — Production Environment
# ============================================================
# Bu faylni serverda /opt/polyglot_crm/backend/.env nomi bilan saqlang
# Hech qachon git'ga commit qilmang!

# --- Asosiy ---
DEBUG=False
SECRET_KEY=GENERATE_A_LONG_RANDOM_STRING_HERE_50_CHARS_MINIMUM
ALLOWED_HOSTS=crm.example.uz,www.crm.example.uz

# --- Domain'lar (CORS + CSRF uchun) ---
FRONTEND_URL=https://crm.example.uz
CSRF_TRUSTED_ORIGINS=https://crm.example.uz,https://www.crm.example.uz
CENTER_URL=https://crm.example.uz

# --- Database (PostgreSQL) ---
USE_SQLITE=False
DB_NAME=polyglot_crm
DB_USER=polyglot
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_EAGER=False

# --- SMS (Eskiz.uz) ---
SMS_PROVIDER=eskiz
SMS_ENABLED=True
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_SENDER=4546

# --- Markaz ---
CENTER_NAME=PolyglotLC
